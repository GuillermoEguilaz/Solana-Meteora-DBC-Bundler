RPC_URL=https://api.mainnet-beta.solana.com

# Base58 private key of the main wallet (creator + tip payer + gather destination)
MAIN_WALLET_PRIVATE_KEY=

# Optional: comma-separated base58 private keys
# If set, this takes precedence over BUNDLER_WALLET_DIR
BUNDLER_WALLET_PRIVATE_KEYS=

# Optional: folder containing bundler wallet JSON files
BUNDLER_WALLET_DIR=wallets

# Jito block engine endpoints (comma-separated)
JITO_BLOCK_ENGINE_URLS=https://mainnet.block-engine.jito.wtf/api/v1/bundles,https://tokyo.mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_TIP_LAMPORTS=5000000

# Max tx per Jito bundle, should stay <= 5
BUNDLE_MAX_TX_PER_BUNDLE=5

# DBC script API settings
DBC_SCRIPT_API_BASE_URL=
DBC_CREATE_ENDPOINT=/create-coin-tx
DBC_BUY_ENDPOINT=/buy-tx
DBC_SELL_ENDPOINT=/sell-tx

# Optional defaults
DEFAULT_QUOTE_MINT=So11111111111111111111111111111111111111112
DEFAULT_PRIORITY_FEE_MICROLAMPORTS=50000
